#include <stdio.h>

int suma(int, int);
static int resta(int, int);

int producto(int, int);
static int cociente(int, int);

/* Funciones */

int suma(int a, int b)
{
    return a + b;
}

static int resta(int a, int b)
{
    return a - b;
}

int producto(int a, int b)
{
    return a * b;
}

static int cociente(int a, int b)
{
    return a / b;
}

/* Función principal */

int main()
{
    int x = 10, y = 5;

    printf("Suma = %d\n", suma(x, y));
    printf("Resta = %d\n", resta(x, y));
    printf("Producto = %d\n", producto(x, y));
    printf("Cociente = %d\n", cociente(x, y));

    return 0;
}
